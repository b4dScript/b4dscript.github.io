---
import BaseLayout from "../layouts/BaseLayout.astro";
import { PROFILE } from "../config";
---

<BaseLayout title="Contact" sideBarActiveItemID="contact">
  <div class="mb-8">
    <p class="text-gray-500 mb-2 font-mono text-sm">
      <span class="text-neon-green">$</span> <span data-i18n="contact.command">cat contact.md</span>
    </p>
    <div class="section-title text-3xl font-bold text-white" data-i18n="contact.title">Contact</div>
    <p class="text-gray-400 mt-2" data-i18n="contact.subtitle">
      Interested in my skills? Let's connect.
    </p>
  </div>

  <div class="grid md:grid-cols-2 gap-4 max-w-2xl">
    <a href={PROFILE.github} target="_blank" class="bg-cyber-card border border-white/10 rounded-xl p-5 card-hover block group">
      <div class="flex items-center gap-4">
        <div class="text-gray-400 group-hover:text-white transition-colors">
          <svg class="w-7 h-7" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
        </div>
        <div>
          <h3 class="text-white font-semibold group-hover:text-neon-green transition-colors" data-i18n="contact.github">GitHub</h3>
          <p class="text-gray-400 text-sm">github.com/{PROFILE.alias}</p>
        </div>
      </div>
    </a>

    <a href={PROFILE.email} class="bg-cyber-card border border-white/10 rounded-xl p-5 card-hover block group">
      <div class="flex items-center gap-4">
        <div class="text-gray-400 group-hover:text-white transition-colors">
          <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
        </div>
        <div>
          <h3 class="text-white font-semibold group-hover:text-neon-green transition-colors" data-i18n="contact.email">Email</h3>
          <p class="text-gray-400 text-sm" data-i18n="contact.emailSub">Send me a message</p>
        </div>
      </div>
    </a>

    <a href={PROFILE.htb} target="_blank" class="bg-cyber-card border border-white/10 rounded-xl p-5 card-hover block group">
      <div class="flex items-center gap-4">
        <div class="text-gray-400 group-hover:text-neon-green transition-colors">
          <svg class="w-7 h-7" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" />
          </svg>
        </div>
        <div>
          <h3 class="text-white font-semibold group-hover:text-neon-green transition-colors" data-i18n="contact.htb">HackTheBox</h3>
          <p class="text-gray-400 text-sm">app.hackthebox.com/profile/{PROFILE.alias}</p>
        </div>
      </div>
    </a>
  </div>

  <div class="mt-10 bg-cyber-card border border-white/10 rounded-xl p-6 max-w-2xl">
    <div class="text-neon-green font-mono text-sm mb-3 terminal-glow">
      <span class="text-gray-400">$</span> <span data-i18n="contact.echo">echo "Let's work together"</span>
    </div>
    <p class="text-gray-400" data-i18n="contact.message">
      I'm currently looking for opportunities in cybersecurity, particularly in penetration testing and security research. 
      Feel free to reach out through any of the channels above.
    </p>
  </div>
</BaseLayout>
