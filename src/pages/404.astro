---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="404 - Not Found" includeSidebar={false}>
  <div class="flex flex-col items-center justify-center min-h-[60vh] text-center">
    <div class="text-6xl font-extrabold text-neon-green mb-4 terminal-glow">404</div>
    <div class="text-2xl text-white mb-2" data-i18n="404.title">Page Not Found</div>
    <p class="text-gray-400 mb-6 font-mono text-sm">
      <span class="text-neon-green">$</span> <span data-i18n="404.message">The page you're looking for doesn't exist</span>
    </p>
    <a href="/" class="btn-terminal-outline px-6 py-2.5 rounded-lg font-mono text-sm" data-i18n="404.btn">
      cd /home
    </a>
  </div>
</BaseLayout>
