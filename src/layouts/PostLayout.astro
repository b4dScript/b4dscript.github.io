---
import BaseLayout from "./BaseLayout.astro";

const { title, description, pubDate, heroImage, badge, tags, updatedDate } = Astro.props;
const formattedDate = pubDate.toLocaleDateString("en-us", {
  year: "numeric",
  month: "short",
  day: "numeric",
});
---

<BaseLayout title={title} description={description} sideBarActiveItemID="writeups">
  <article>
    <div class="mb-8">
      <div class="flex items-center gap-3 mb-4">
        {badge && <span class="badge badge-easy">{badge}</span>}
        <time class="text-gray-400 text-sm">{formattedDate}</time>
        {updatedDate && <span class="text-gray-400 text-sm">(updated: {updatedDate})</span>}
      </div>
      <h1 class="text-3xl md:text-4xl font-extrabold text-white mb-2">{title}</h1>
      {tags && tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mt-4">
          {tags.map((tag) => (
            <span class="badge badge-easy text-xs">{tag}</span>
          ))}
        </div>
      )}
    </div>

    {heroImage && (
      <div class="mb-8 rounded-xl overflow-hidden border border-white/10">
        <img src={heroImage} alt={title} class="w-full object-cover" />
      </div>
    )}

    <div class="prose prose-invert prose-p:text-gray-400 prose-li:text-gray-400 prose-headings:text-white prose-a:text-neon-green prose-code:text-neon-green prose-pre:bg-cyber-gray prose-pre:border prose-pre:border-white/10 prose-strong:text-neon-green max-w-none">
      <slot />
    </div>
  </article>
</BaseLayout>
