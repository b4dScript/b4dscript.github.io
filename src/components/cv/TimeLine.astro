---
interface Props {
  title: string;
  subtitle: string;
  titleI18n?: string;
  subtitleI18n?: string;
  descI18n?: string;
}

const { title, subtitle, titleI18n, subtitleI18n, descI18n } = Astro.props;
---

<div class="relative pl-6 border-l-2 border-neon-green/30 pb-6 last:pb-0">
  <div class="absolute -left-[9px] top-0 w-4 h-4 bg-cyber-black border-2 border-neon-green rounded-full"></div>
  <div class="bg-cyber-card border border-white/10 rounded-xl p-5 card-hover">
    <h3 class="text-neon-green font-bold terminal-glow" data-i18n={titleI18n}>{title}</h3>
    <p class="text-gray-400 text-sm mt-1" data-i18n={subtitleI18n}>{subtitle}</p>
    <div class="mt-2 text-gray-300 text-sm" data-i18n={descI18n}>
      <slot />
    </div>
  </div>
</div>
