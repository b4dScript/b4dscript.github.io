---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<header class="navbar bg-cyber-gray/80 backdrop-blur-sm border-b border-white/5 px-4 lg:hidden">
  <div class="flex-1">
    <label for="my-drawer" class="btn btn-ghost text-gray-400">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 15h16" />
      </svg>
    </label>
  </div>
</header>
