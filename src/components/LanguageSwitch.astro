---
---

<button
  id="lang-switch"
  class="flex items-center gap-2 px-3 py-1.5 text-xs font-medium text-gray-400 hover:text-neon-green bg-white/5 hover:bg-white/10 rounded-lg transition-all duration-200"
  aria-label="Toggle language"
>
  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129" />
  </svg>
  <span id="lang-label">EN</span>
</button>

<script>
  const SUPPORTED_LANGS = ["en", "es"];

  function getTranslations(): any {
    return (window as any).__TRANSLATIONS__ || {};
  }

  function getLang(): string {
    if (typeof localStorage !== "undefined") {
      const saved = localStorage.getItem("lang");
      if (saved && SUPPORTED_LANGS.includes(saved)) return saved;
    }
    return "en";
  }

  function setLang(lang: string) {
    localStorage.setItem("lang", lang);
    applyLang(lang);
  }

  function applyLang(lang: string) {
    document.documentElement.setAttribute("data-lang", lang);

    const label = document.getElementById("lang-label");
    if (label) label.textContent = lang.toUpperCase();

    const t = getTranslations();
    const langData = t[lang];
    if (!langData) return;

    document.querySelectorAll("[data-i18n]").forEach((el) => {
      const key = el.getAttribute("data-i18n");
      if (!key) return;
      const parts = key.split(".");
      let value: any = langData;
      for (const part of parts) {
        if (value && typeof value === "object") value = value[part];
        else { value = null; break; }
      }
      if (typeof value === "string") {
        el.textContent = value;
      }
    });
  }

  function cycleLang() {
    const current = getLang();
    const idx = SUPPORTED_LANGS.indexOf(current);
    const next = SUPPORTED_LANGS[(idx + 1) % SUPPORTED_LANGS.length];
    setLang(next);
  }

  document.getElementById("lang-switch")?.addEventListener("click", cycleLang);

  function init() {
    const script = document.createElement("script");
    script.src = "/lang.js";
    script.onload = () => applyLang(getLang());
    document.head.appendChild(script);
  }

  if ((window as any).__TRANSLATIONS__) {
    applyLang(getLang());
  } else {
    init();
  }
</script>
